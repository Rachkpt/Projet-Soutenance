# Copier ce fichier en .env dans le même dossier que docker-compose.yml
# Ne JAMAIS committer le fichier .env réel (il est dans .gitignore)

# Clé de signature des sessions TheHive (cookies, tokens)
THEHIVE_SECRET_KEY=<GENERER_AVEC: openssl rand -hex 32>

# Clé de signature Cortex (play.http.secret.key dans application.conf)
CORTEX_SECRET_KEY=<GENERER_AVEC: openssl rand -hex 32>

# Identifiants du stockage S3 (Minio) utilisé par TheHive pour les pièces jointes
MINIO_ROOT_USER=<A_DEFINIR>
MINIO_ROOT_PASSWORD=<GENERER_AVEC: openssl rand -hex 24>
