# ╔══════════════════════════════════════════════════════════╗
# ║       SOC AUTOMATION PRO — CONFIGURATION                ║
# ╚══════════════════════════════════════════════════════════╝
#
# Copier ce fichier en .env dans ce même dossier.
# Ne JAMAIS committer le fichier .env réel (il est dans .gitignore).

# ── WAZUH — API Manager (agents, config — PAS les alertes) ──
WAZUH_URL=https://IP_WAZUH_MANAGER:55000
WAZUH_USER=wazuh
WAZUH_PASS=<GENERER: mot de passe API Wazuh manager>
WAZUH_MIN_LEVEL=5
WAZUH_POLL_INTERVAL=30
WAZUH_ALERT_LIMIT=100

# ── WAZUH INDEXER (OpenSearch — endpoint réel des alertes) ─
# ATTENTION: différent de l'API manager ci-dessus. C'est ici
# que vivent les vraies alertes (index wazuh-alerts-*).
# Voir docs/08-automatisation-soc/source-des-donnees.md
WAZUH_INDEXER_URL=https://IP_WAZUH_INDEXER:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=<GENERER: mot de passe Wazuh Indexer>

# ── THEHIVE (Case Management) ─────────────────────────────
THEHIVE_URL=http://IP_THEHIVE:9000
THEHIVE_API=<GENERER: clé API d'un compte dans une organisation dédiée, PAS "admin" — voir docs/06-thehive-cortex/organisation-setup.md>
THEHIVE_TLP=2
THEHIVE_PAP=2
THEHIVE_ORG=<A_DEFINIR: nom de l'organisation TheHive dédiée>

# ── CORTEX (Analyse) ──────────────────────────────────────
CORTEX_URL=http://IP_CORTEX:9001
CORTEX_API=<GENERER: clé API Cortex>
CORTEX_TIMEOUT=180
CORTEX_POLL=10
CORTEX_TLP=2

# ── GROQ (IA — synthèse des résultats d'analyse) ──────────
GROQ_API_KEY=<GENERER: clé API sur https://console.groq.com/>
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.3

# ── GMAIL (notifications par email) ───────────────────────
GMAIL_SENDER=<A_DEFINIR>
GMAIL_PASSWORD=<GENERER: mot de passe d'application Gmail — https://myaccount.google.com/apppasswords — PAS le mot de passe du compte>
# Plusieurs destinataires possibles, séparés par des virgules.
# Seul l'expéditeur (GMAIL_SENDER) a besoin d'un mot de passe d'application —
# les destinataires n'en ont besoin d'aucun (Gmail, Outlook, Yahoo...).
GMAIL_RECEIVER=<A_DEFINIR: ex. toi@gmail.com,collegue@outlook.com>
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# ── TELEGRAM (bot d'administration + notifications) ───────
TELEGRAM_TOKEN=<GENERER: via @BotFather sur Telegram>
TELEGRAM_CHAT=<A_DEFINIR: ton chat_id Telegram>

# ── SURICATA ──────────────────────────────────────────────
SURICATA_ENABLE=true
SURICATA_EVE=/var/log/suricata/eve.json

# ── FAIL2BAN ──────────────────────────────────────────────
FAIL2BAN_ENABLE=true
FAIL2BAN_JAIL=soc-auto
FAIL2BAN_BANTIME=7200

# ── FIREWALL ──────────────────────────────────────────────
# Choix: iptables | nftables
FIREWALL_BACKEND=iptables
IPTABLES_CHAIN=SOC_GUARD
NFTABLES_TABLE=soc_guard
NFTABLES_CHAIN=soc_input
BLOCK_DURATION=7200
HOME_NET=<A_DEFINIR: ton réseau local en notation CIDR, ex. 10.0.0.0/8>
WHITELIST_IPS=127.0.0.1,::1

# ── FICHIERS ──────────────────────────────────────────────
STATE_FILE=/opt/soc-automation/soc_state.json
LOG_FILE=/var/log/soc_automation.log

# ── EMAIL EVENTS ──────────────────────────────────────────
MAIL_ON_BLOCK=true
MAIL_ON_CASE=true
MAIL_ON_MALWARE=true
MAIL_ON_SSH=false
MAIL_ON_START=true
